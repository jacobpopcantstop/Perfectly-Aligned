# Perfectly Aligned - Environment Configuration

# Server port
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# Enable CORS for specific origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Room cleanup interval (milliseconds) - how often to check for stale rooms
ROOM_CLEANUP_INTERVAL=60000

# Room timeout (milliseconds) - how long before inactive rooms are removed
ROOM_TIMEOUT=1800000
